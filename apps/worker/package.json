{
  "name": "@ecommerce/worker",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "main": "dist/worker.js",
  "scripts": {
    "dev": "tsx watch src/worker.ts",
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "start": "node dist/worker.js",
    "lint": "eslint src --ext .ts",
    "test": "node --import tsx --test src/**/*.test.ts",
    "postinstall": "prisma generate --schema ../backend/prisma/schema.prisma"
  },
  "dependencies": {
    "@ecommerce/queue": "workspace:*",
    "@prisma/client": "^6.5.0",
    "bullmq": "^5.60.0",
    "dotenv": "^16.4.7",
    "pino": "^9.7.0",
    "postmark": "^4.0.5",
    "stripe": "^18.5.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.9",
    "prisma": "^6.5.0",
    "tsc-alias": "^1.8.11",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3"
  }
}
