{
  "name": "ecommerce-monorepo",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.6.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm -r --parallel --filter @ecommerce/backend --filter @ecommerce/frontend dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "format": "prettier --write .",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "prisma:migrate": "DATABASE_URL=${DATABASE_URL:-postgresql://ecommerce:ecommerce@localhost:5432/ecommerce?schema=public} pnpm --filter @ecommerce/backend prisma:migrate",
    "prisma:seed": "DATABASE_URL=${DATABASE_URL:-postgresql://ecommerce:ecommerce@localhost:5432/ecommerce?schema=public} pnpm --filter @ecommerce/backend prisma:seed"
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "eslint": "^9.20.1",
    "eslint-plugin-import": "^2.31.0",
    "prettier": "^3.5.1",
    "typescript-eslint": "^8.24.0"
  }
}
